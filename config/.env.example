# ── Polymarket Copy-Bot Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Wallet to follow (pre-filled with your target)
TARGET_ADDRESS=0x8d1d5d1c6041b13fc708b5d9f668070e1724ed4a

# Your fixed budget per copied trade (USD)
BUDGET_USD=12

# Polling interval in seconds (how often to check for new trades)
POLL_INTERVAL=15

# ── Live trading (leave DRY_RUN=true to simulate only) ──────────────────────
DRY_RUN=true

# Your Polymarket proxy wallet private key (KEEP SECRET — never commit this)
PRIVATE_KEY=

# Your proxy wallet address (visible in Polymarket profile dropdown)
FUNDER_ADDRESS=

# Signature type: 1=POLY_PROXY (Magic Link), 2=GNOSIS_SAFE (MetaMask/Rabby)
SIGNATURE_TYPE=2
